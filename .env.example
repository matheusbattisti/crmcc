# Modelo das variáveis de ambiente do CRM.
# NÃO coloque valores reais aqui — este arquivo é público (vai pro Git).
# No seu PC: copie para .env.local e preencha.
# Na hospedagem: cadastre cada uma destas no painel (Environment Variables).

# Supabase (banco de dados)
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Login do administrador
ADMIN_USUARIO=
ADMIN_SENHA_HASH=

# Chave interna da sessão (uma string longa e aleatória)
SESSION_TOKEN=

# IA (Claude / Anthropic)
ANTHROPIC_API_KEY=
